# =============================================================================
# TerraFlow Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values for local dev.
# `.env.local` is gitignored — never commit real secrets.
# In production (Netlify), set these in Site settings > Environment variables.
#
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser bundle.
# Everything else is server-only and must NEVER be referenced in client code.
# =============================================================================

# ---------- App ----------
# Public base URL — used to build redirect URLs (Stripe, magic links, etc.)
# Local: http://localhost:3000
# Prod:  https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Stripe ----------
# Server-only secret key (sk_test_... in dev, sk_live_... in prod)
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...) — get from Stripe Dashboard after
# registering your webhook endpoint, or from `stripe listen` for local dev.
STRIPE_WEBHOOK_SECRET=

# Public publishable key (pk_test_... / pk_live_...) — safe to expose
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Platform fee in basis points (100 = 1%, 250 = 2.5%). Default 0 = no fee.
STRIPE_PLATFORM_FEE_BPS=0

# ---------- Google Maps ----------
# Browser key — protected by Google Cloud Console restrictions
# (HTTP referrer allowlist + API allowlist + billing cap), NOT by hiding it.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=

# ---------- Postmark (transactional email) ----------
# Postmark Dashboard → Servers → [your server] → API Tokens
POSTMARK_SERVER_TOKEN=

# Verified sender email — must match a Sender Signature in Postmark
# (or use a verified Domain). Domain verification requires SPF + DKIM DNS records.
POSTMARK_FROM_EMAIL=

# Optional: message stream ID. Defaults to "outbound" (the transactional stream).
# Use a separate stream like "broadcast" for marketing emails.
POSTMARK_MESSAGE_STREAM=outbound

# ---------- Twilio (SMS) ----------
# Twilio Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio phone number in E.164 format (e.g. +13035551234)
# To send to US numbers at scale you must complete A2P 10DLC registration first.
TWILIO_FROM_NUMBER=

# ---------- Magic links ----------
# Used to sign HMAC tokens for one-time bid view, login, and payment links.
# Must be at least 32 chars. Generate with: openssl rand -hex 32
MAGIC_LINK_SECRET=
